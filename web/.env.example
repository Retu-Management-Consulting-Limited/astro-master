# Molly — environment template. Copy to .env.local and fill in.
# Nothing below is required to run the app in dev (readings fall back to the
# deterministic stub). Add only what you want to enable.

# Russian UI exposure. Russian is fully built but NOT shown to users by default
# (Kevin: 俄语暂不对用户开). Set to 1 to expose: LocaleSwitcher lists Русский and
# /ru/* becomes reachable. Unset/0 → ru hidden, manual /ru/* redirects back to
# the default locale. Tests/CI set this to 1 so the ru e2e specs can hit /ru.
# Flip to 1 in production after native-language review — no code change needed.
NEXT_PUBLIC_RU_PUBLIC=

# Molly AI readings (app/api/reading). Set to 1 to use real Claude readings;
# unset/0 → instant deterministic stub (tests/CI run this way).
NEXT_PUBLIC_MOLLY_AI=

# Model tier for readings: haiku | sonnet | opus (default sonnet).
# MOLLY_MODEL=sonnet

# Auth for AI routes (/api/reading, /api/chat):
#  - LOCAL/PILOT: leave ANTHROPIC_API_KEY unset → reuses your Claude Code
#    subscription login. (Subscription auth is NOT allowed to serve real users,
#    and cannot be deployed — the engine subprocess can't run on serverless.)
#  - CLOUD / real testers: set a Console API key here → fast (~3s) + deployable.
ANTHROPIC_API_KEY=

# --- Internal test (5-10 人内测) ---
# Telemetry + feedback button + tester cookie. 1 = on. Off → no tracking (prod/CI).
NEXT_PUBLIC_MOLLY_TEST=
# Guards the /admin dashboard + GET /api/admin/export  (long random string)
ADMIN_SECRET=
# Optional short, memorable password for the /admin login (falls back to
# ADMIN_SECRET if unset). Set this so you don't type the long secret.
ADMIN_PASSWORD=

# KV for the readings cache + tester data/events/feedback. Without these the
# store falls back to in-memory (fine locally; NOT for multi-instance cloud).
# Vercel KV marketplace sets KV_REST_API_URL / KV_REST_API_TOKEN automatically.
# Upstash standalone:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# TODO(geo): real geocoding + historical timezone (replaces the built-in city table).
# GEOCODING_API_KEY=

# TODO(push): Web Push (VAPID) for daily / wealth / synastry reminders.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
